{
  "name": "h402",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @h402/core && npm run build -w @h402/cli",
    "typecheck": "npm run build -w @h402/core && npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "verify:pack": "node scripts/verify-pack.mjs",
    "smoke:pack": "node scripts/smoke-pack.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
